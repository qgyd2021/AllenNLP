{
    "dataset_reader": {
        "type": "text_classification_json_utf8",
        "token_indexers": {
            "tokens": {
                "type": "single_id",
                "namespace": "tokens",
                "lowercase_tokens": true,
                "token_min_padding_length": 9
            }
        },
        "tokenizer": {
            "type": "pretrained_transformer",
            "model_name": "D:/Users/Administrator/PycharmProjects/AllenNLP/pretrained_models/dienstag/chinese-bert-wwm-ext",
            "max_length": 512
        }
    },
    "train_data_path": "train.jsonl",
    "validation_data_path": "valid.jsonl",
    "vocabulary": {
        "directory_path": "vocabulary"
    },
    "model": {
        "type": "basic_classifier",
        "text_field_embedder": {
            "token_embedders": {
                "tokens": {
                    "type": "embedding",
                    "num_embeddings": 21129,
                    "embedding_dim": 128
                }
            }
        },
        "seq2vec_encoder": {
            "type": "cnn",
            "embedding_dim": 128,
            "num_filters": 128,
            "ngram_filter_sizes": [1, 2, 3, 4, 5, 6, 7, 8, 9]
        }
    },
    "data_loader": {
        "type": "multiprocess",
        "batch_size": 64,
        "shuffle": true
    },
    "trainer": {
        "type": "gradient_descent",
        "cuda_device": -1,
        "optimizer": {
            "type": "adam",
            "lr": 0.001
        },
        "checkpointer": {
            "serialization_dir": "serialization_dir",
            "keep_most_recent_by_count": 10
        },
        "patience": 5,
        "validation_metric": "+accuracy",
        "num_epochs": 100
    }
}
